{
  "manifest_version": 3,
  "name": "Dynamic Rounding",
  "version": "1.1.0",
  "description": "Applies dynamic rounding to tables on arbitrary websites.",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {}
}
