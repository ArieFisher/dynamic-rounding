{
  "manifest_version": 3,
  "name": "Dynamic Rounding",
  "version": "2.0.1",
  "description": "Applies dynamic rounding to tables on arbitrary websites.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "defaults.js",
        "content.js"
      ]
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
